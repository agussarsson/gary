DATABASE_URL=postgresql://gary:gary_pw@localhost:5432/gary_db
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AUTH_MAX_USERS=5
LLM_MAX_CALLS=10
SESSION_TTL_HOURS=24
# Set true in production HTTPS environments
COOKIE_SECURE=false

# Next.js (copy into web/.env.local or set before `npm run dev` in web/):
# Leave empty so the browser calls same-origin /backend-api/* (rewritten to FastAPI). Avoids cross-origin "Failed to fetch" to 127.0.0.1:8000 in some browsers.
# For production, set the public API URL, e.g. https://api.example.com
NEXT_PUBLIC_API_BASE_URL=

# Optional: if FastAPI is not on 127.0.0.1:8000, set for Next rewrites (web dev server only)
# GARY_API_PROXY_TARGET=http://127.0.0.1:8000

# Optional: Gemini program generation/refinement (falls back to a template if unset)
# GEMINI_API_KEY=
# Or: GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
